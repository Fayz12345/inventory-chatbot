# Marketplace credentials for the ecommerce auto-listing flow (1D.4 / 1D.5 / 1D.6).
#
# Copy this file to `.env`, fill in the values, and the app loads them at startup
# (via python-dotenv in app.py). `.env` is gitignored.
#
# The `*_ENV` toggles let you have BOTH sandbox and production credentials in
# this file at the same time, then switch by changing one variable. Default to
# `sandbox` while developing; flip to `production` ONLY when ready to post real
# listings.

# ===========================================================================
# Amazon SP-API (ticket 1D.4 — #136)
# ---------------------------------------------------------------------------
# Sign up: Seller Central -> Apps & Services -> Develop Apps
# Sandbox docs: developer-docs.amazon.com/sp-api/docs/connecting-to-the-selling-partner-api-sandbox
# ===========================================================================

# 'sandbox' | 'production' — default sandbox; flip when ready to go live.
AMAZON_ENV=sandbox

# Marketplace ID — same for both envs (A2EUQ1WTGCTBG2 = Amazon.ca).
AMAZON_MARKETPLACE_ID=A2EUQ1WTGCTBG2

# --- Sandbox (test posts only — never visible on real amazon.ca) ---
AMAZON_SELLER_ID_SANDBOX=
AMAZON_REFRESH_TOKEN_SANDBOX=
AMAZON_LWA_APP_ID_SANDBOX=
AMAZON_LWA_CLIENT_SECRET_SANDBOX=

# --- Production (REAL listings on amazon.ca — leave blank until ready) ---
AMAZON_SELLER_ID=
AMAZON_REFRESH_TOKEN=
AMAZON_LWA_APP_ID=
AMAZON_LWA_CLIENT_SECRET=


# ===========================================================================
# eBay API (ticket 1D.5 — #137)
# ---------------------------------------------------------------------------
# Sign up: developer.ebay.com -> My Account -> Application Keys
# Sandbox + sandbox seller account at: developer.ebay.com -> Sandbox
# ===========================================================================

# 'sandbox' | 'production' — default sandbox.
EBAY_ENV=sandbox

# Marketplace + category — same for both envs. 9355 = Cell Phones & Smartphones.
EBAY_MARKETPLACE_ID=EBAY_CA
EBAY_CATEGORY_ID=

# --- Sandbox (api.sandbox.ebay.com — separate sandbox seller account needed) ---
EBAY_APP_ID_SANDBOX=
EBAY_CERT_ID_SANDBOX=
EBAY_REFRESH_TOKEN_SANDBOX=
# publishOffer prerequisites — per-account merchant location + 3 business policy IDs.
EBAY_MERCHANT_LOCATION_KEY_SANDBOX=
EBAY_FULFILLMENT_POLICY_ID_SANDBOX=
EBAY_PAYMENT_POLICY_ID_SANDBOX=
EBAY_RETURN_POLICY_ID_SANDBOX=

# --- Production (api.ebay.com — REAL listings on ebay.ca) ---
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_REFRESH_TOKEN=
# publishOffer prerequisites — fill from the live eBay account.
EBAY_MERCHANT_LOCATION_KEY=
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=


# ===========================================================================
# Reebelo CA — "Cobalt" custom API (ticket 1D.12)
# ---------------------------------------------------------------------------
# Auth = static API key in the x-api-key header. Base URL is env-derived
# (sandbox a.reebelo.blue / prod a.reebelo.com) unless REEBELO_API_BASE is set.
# Auto-posts on approve ONLY when REEBELO_API_KEY* is set, else preview-only.
# USERNAME/PASSWORD slots are legacy/unused by Cobalt.
# ===========================================================================

REEBELO_ENV=sandbox
REEBELO_API_BASE=
REEBELO_USERNAME=
REEBELO_PASSWORD=
REEBELO_API_KEY=
REEBELO_USERNAME_SANDBOX=
REEBELO_PASSWORD_SANDBOX=
REEBELO_API_KEY_SANDBOX=


# ===========================================================================
# Best Buy Canada Marketplace (Mirakl) — ticket 1D.11
# ---------------------------------------------------------------------------
# Single PRODUCTION instance (no sandbox) — creating an offer posts a REAL
# listing. Only state "11" (New) is offered; grade goes in the description.
# ===========================================================================
BESTBUY_API_BASE=https://marketplace.bestbuy.ca/api
BESTBUY_API_KEY=
BESTBUY_STATE_CODE=11
BESTBUY_LOGISTIC_CLASS=SMALL
BESTBUY_LEADTIME_TO_SHIP=4
BESTBUY_PRODUCT_ID_TYPE=UPC-A
BESTBUY_MANUFACTURER_WARRANTY=365
